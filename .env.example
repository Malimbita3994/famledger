APP_NAME=famledger
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use the same host you open in the browser (e.g. http://127.0.0.1:8000) or the contact form POST may hit the wrong origin.
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=famledger
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting: use `reverb` for real-time dashboard updates (run `php artisan reverb:start` in another terminal).
# Set to `null` to disable WebSockets; `log` only logs events locally.
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=famledger
REVERB_APP_KEY=famledger-key
REVERB_APP_SECRET=famledger-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# OAuth — Sign in with Google / Apple (optional). Register redirect URIs in each provider console; they must match APP_URL.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# Path to AuthKey_xxx.p8 or paste PEM contents (see socialiteproviders/apple docs)
# APPLE_PRIVATE_KEY=
# APPLE_REDIRECT_URI="${APP_URL}/auth/apple/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Contact form spam protection: math (default, no third parties) | recaptcha | none
# CONTACT_CAPTCHA_DRIVER=math
# If you only had RECAPTCHA_* set before, add CONTACT_CAPTCHA_DRIVER=recaptcha to keep using Google.
#
# Google reCAPTCHA v2 — only when CONTACT_CAPTCHA_DRIVER=recaptcha
# https://www.google.com/recaptcha/admin — use "I'm not a robot" v2 keys.
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=

# FamLedger financial year (default: Jan 1 – Dec 31). Uncomment to use a different fiscal year.
# FAMLEDGER_FY_START_MONTH=1
# FAMLEDGER_FY_START_DAY=1
# FAMLEDGER_FY_END_MONTH=12
# FAMLEDGER_FY_END_DAY=31

# Plain password for brand-new users created when a family member is added by email (web + API). Set a strong value in production.
# FAMLEDGER_DEFAULT_NEW_MEMBER_PASSWORD=FamLedgerMember123!

# Demo dataset (staging): when true, `php artisan db:seed` also runs DemoFamilySeeder (sample family + transactions).
# Or run only: php artisan db:seed --class=DemoFamilySeeder
# FAMLEDGER_DEMO_SEED=false
# FAMLEDGER_DEMO_USER_EMAIL=demo@famledger.local
# FAMLEDGER_DEMO_USER_PASSWORD=password
# FAMLEDGER_DEMO_FAMILY_NAME="Rivera family (demo)"

# Elasticsearch (transaction search — optional; leave disabled if not running a cluster)
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_HOSTS=http://127.0.0.1:9200
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_TRANSACTIONS=famledger_transactions
# ELASTICSEARCH_SEARCH_SIZE=15
# ELASTICSEARCH_SEARCH_SIZE_MAX=50
# ELASTICSEARCH_CACHE_TTL=60

# Firebase (Admin SDK)
# Path to service account JSON, e.g. storage/app/firebase/service-account.json
FIREBASE_CREDENTIALS=
# Alternative: paste entire service-account JSON in one line (avoid in production if possible)
FIREBASE_CREDENTIALS_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=
